{
  "name": "family-history-intake-form",
  "version": "0.1.0",
  "description": "Evagene integration example: web form that turns three generations of family history into a fully-structured pedigree via the REST API.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "start": "tsx src/main.ts",
    "test": "node --import tsx --test test/evageneClient.test.ts test/intakeService.test.ts test/intakeSubmission.test.ts",
    "lint": "eslint src test",
    "format": "prettier --write src test",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {
    "express": "5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "9.16.0",
    "@types/express": "5.0.0",
    "@types/node": "22.10.2",
    "eslint": "9.16.0",
    "prettier": "3.4.2",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "typescript-eslint": "8.18.1"
  }
}
