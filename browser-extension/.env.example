# Build-time configuration only. The extension reads its runtime base URL
# from browser.storage.local (set on the Options page), so this value is only
# embedded as the *default* the Options page shows the first time it is opened.
#
# Leave unset to keep the production default (https://evagene.net). Override
# while you are running Evagene locally from the product repo.
EVAGENE_BASE_URL=https://evagene.net
